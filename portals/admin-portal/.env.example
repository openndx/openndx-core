# =============================================================================
# Admin Portal - Environment Variables
# =============================================================================
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# Two independent configuration mechanisms are in play:
#
# 1. BUILD-TIME variables (VITE_PORT, VITE_BASE_PATH) are read via Vite's
#    `import.meta.env` / `loadEnv()` (see vite.config.ts). Values here DO
#    affect `npm run dev` and `npm run build`.
#
# 2. RUNTIME variables (everything else below) are read from the global
#    `window.configs` object at browser runtime (see src/main.tsx,
#    src/App.tsx, src/services/*.ts). `window.configs` is populated by
#    entrypoint.sh, which writes /usr/share/nginx/html/config.js from
#    container environment variables when the Docker image starts. Values
#    in THIS FILE have NO EFFECT on `window.configs` - Vite never loads
#    `.env` into it. To exercise these locally under `npm run dev`,
#    generate public/config.js via `../setup-portals.sh` (run from
#    portals/) or create it by hand - see README.md.
# =============================================================================

# --- Build-time (Vite dev server / build) ---
VITE_PORT=5173
VITE_BASE_PATH=/

# --- Runtime (window.configs - see entrypoint.sh / public/config.js) ---
VITE_API_URL=http://localhost:3000
VITE_LOGS_URL=http://localhost:3001
VITE_IDP_CLIENT_ID=your_client_id
VITE_IDP_BASE_URL=https://api.asgardeo.io/t/your-org
VITE_IDP_SCOPE=openid,profile
VITE_IDP_ADMIN_ROLE=admin
VITE_SIGN_IN_REDIRECT_URL=http://localhost:5173
VITE_SIGN_OUT_REDIRECT_URL=http://localhost:5173
