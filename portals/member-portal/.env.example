# =============================================================================
# Member Portal - Environment Variables
# =============================================================================
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# See admin-portal/.env.example for the full build-time vs. runtime
# (window.configs) explanation. Short version: only VITE_PORT and
# VITE_BASE_PATH below affect `npm run dev` / `npm run build` directly. All
# other variables are consumed via `window.configs`, populated by
# entrypoint.sh in Docker or a manually created public/config.js locally
# (run `../setup-portals.sh` from portals/, or see README.md).
# =============================================================================

# --- Build-time (Vite dev server / build) ---
VITE_PORT=5173
VITE_BASE_PATH=/

# --- Runtime (window.configs - see entrypoint.sh / public/config.js) ---
VITE_API_URL=http://localhost:3000
VITE_LOGS_URL=http://localhost:3001
VITE_CLIENT_ID=your_client_id
VITE_BASE_URL=https://api.asgardeo.io/t/your-org
VITE_SCOPE=openid,profile
VITE_SIGN_IN_REDIRECT_URL=http://localhost:5173
VITE_SIGN_OUT_REDIRECT_URL=http://localhost:5173
