# Consent Engine Environment Variables Template
# Copy this file to .env and update with your actual values
# =============================================================================
# Service Configuration
# =============================================================================
PORT=8081
HOST=0.0.0.0
ENVIRONMENT=local
CONSENT_PORTAL_URL=
# Add Comma Separated, (CONSENT_PORTAL_URL will be auto added)
CORS_ALLOWED_ORIGINS=

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=consent_engine
DB_SSLMODE=require

# Auto-create tables on startup (true|false)
RUN_MIGRATION=false

# =============================================================================
# Migration Configuration
# =============================================================================
RUN_MIGRATION=false

# =============================================================================
# IDP Configuration
# =============================================================================
IDP_ORG_NAME=YOUR_ORG_NAME
IDP_ISSUER=
IDP_AUDIENCE=YOUR_AUDIENCE
IDP_JWKS_URL=
