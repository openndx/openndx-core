# Consent Engine Environment Variables
# Copy this file to .env and update with your actual values
# =============================================================================
# Service Configuration
# =============================================================================
PORT=8081
HOST=0.0.0.0
ENVIRONMENT=local
CONSENT_PORTAL_URL=
# Add Comma Separated, (CONSENT_PORTAL_URL will be auto added)
CORS_ALLOWED_ORIGINS=

# =============================================================================
# Migration Configuration
# =============================================================================
RUN_MIGRATION=false

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=consent_engine
DB_SSLMODE=require

# Auto-create tables on startup (true|false)
RUN_MIGRATION=false

# =============================================================================
# IDP Configuration
# =============================================================================
# The verifier validates issuer, audience, and client_id when each is set,
# extracts the email claim, and is otherwise IdP-agnostic (no organization claim).
IDP_ISSUER=
IDP_AUDIENCE=
IDP_CLIENT_ID=
IDP_JWKS_URL=
# Dev-only: skip TLS verification on the JWKS fetch (e.g. a self-signed local
# IdP). Leave false in production.
IDP_JWKS_INSECURE_SKIP_VERIFY=false
