# Exchange Services - Local Development Environment
# Generated for local development and testing

# Environment Configuration
ENVIRONMENT=local
LOG_LEVEL=info
LOG_FORMAT=text

# Build Configuration
BUILD_VERSION=dev
BUILD_TIME=2025-09-15T14:30:00Z
GIT_COMMIT=local

# Service Ports
PORT_PDP=8082
PORT_CE=8081
PORT_OE=4000

# Service Configuration
CONSENT_PORTAL_URL=http://localhost:5173

# Database Configuration
# These match the bundled postgres service in docker-compose.yml.
PORT_DB=5432
DB_HOST=postgres
DB_PORT=5432
DB_USER=exchange
DB_PASSWORD=exchange
DB_SSLMODE=disable
# Per-service database names (created by init-db.sql)
DB_NAME_PDP=pdp
DB_NAME_CE=consent_engine
DB_NAME_OE=orchestration_engine
# Auto-create tables on startup
RUN_MIGRATION=true

# Telemetry
OTEL_METRICS_EXPORTER=prometheus

# IDP Configuration (consent-engine JWT verification for portal endpoints)
# The verifier validates issuer, audience, and client_id when each is set,
# extracts the email claim, and is otherwise IdP-agnostic.
IDP_ISSUER=
IDP_AUDIENCE=
IDP_CLIENT_ID=
IDP_JWKS_URL=
# Dev-only: skip TLS verification on the JWKS fetch (e.g. a self-signed local
# IdP). Leave false in production.
IDP_JWKS_INSECURE_SKIP_VERIFY=false
