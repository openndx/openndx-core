# Database Configuration for Cloud PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD={YOUR_PASSWORD_HERE}
DB_NAME=management-db
DB_SSLMODE=require

PDP_SERVICE_URL=http://localhost:8082

# Audit Service Configuration (Optional)
# If omitted or ENABLE_AUDIT=false, auditing is disabled and services run normally.
# AUDIT_SERVICE_URL=http://localhost:3001
# ENABLE_AUDIT=true

# Server Configuration
PORT=3000
CORS_ALLOWED_ORIGINS=*

# Set to "true" only when you need to run migrations
RUN_MIGRATION=false

# IDP Configuration
IDP_CLIENT_ID={YOUR_IDP_CLIENT_ID_HERE}
IDP_CLIENT_SECRET={YOUR_IDP_CLIENT_SECRET_HERE}
IDP_BASE_URL={YOUR_IDP_BASE_URL_HERE}
IDP_SCOPE={YOUR_IDP_SCOPE_HERE}

IDP_TOKEN_URL={YOUR_IDP_BASE_URL_HERE}/oauth2/token

# IDP JWT Authentication Configuration
IDP_ISSUER={YOUR_IDP_ISSUER_URL_HERE}
IDP_JWKS_URL={YOUR_IDP_BASE_URL_HERE}/oauth2/jwks

# Client IDs used by different portals (Need to validate JWT token claims)
IDP_MEMBER_PORTAL_CLIENT_ID={YOUR_MEMBER_PORTAL_CLIENT_ID_HERE}
IDP_ADMIN_PORTAL_CLIENT_ID={YOUR_ADMIN_PORTAL_CLIENT_ID_HERE}

# Roles used by different portals
IDP_MEMBER_PORTAL_ROLE={YOUR_MEMBER_PORTAL_ROLE_HERE}
IDP_ADMIN_PORTAL_ROLE={YOUR_ADMIN_PORTAL_ROLE_HERE}

# Authorization Configuration
# Controls behavior when no explicit permission is defined for an endpoint
# Options: fail_closed (most secure, deny all), fail_open_admin (allow admin only), fail_open_admin_system (allow admin/system)
AUTHORIZATION_MODE=fail_open_admin_system

# Enable strict mode to log warnings about undefined endpoints (helps identify missing permission mappings)
# Options: true, false
AUTHORIZATION_STRICT_MODE=false